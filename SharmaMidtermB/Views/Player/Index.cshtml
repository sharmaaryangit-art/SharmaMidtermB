@model IEnumerable<SharmaMidtermB.Models.Player>

@{
    ViewData["Title"] = "Players";
}

<h1>Players</h1>

@if (User.IsInRole("Admin"))
{
    <p>
        <a asp-action="Create">Create New</a>
    </p>
}

<table class="table">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.Name)</th>
            <th>@Html.DisplayNameFor(model => model.Position)</th>
            <th>@Html.DisplayNameFor(model => model.ShirtNumber)</th>
            <th>@Html.DisplayNameFor(model => model.FirstMatch)</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model) {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.Name)</td>
                <td>@Html.DisplayFor(modelItem => item.Position)</td>
                <td>@Html.DisplayFor(modelItem => item.ShirtNumber)</td>
                <td>@Html.DisplayFor(modelItem => item.FirstMatch)</td>
            </tr>
        }
    </tbody>
</table>